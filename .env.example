# =============================================================================
# CognitaAI Mobile — Variables de entorno
# Copia este archivo como .env y reemplaza los valores reales
# NUNCA subas .env a GitHub
# =============================================================================

# --- Supabase ---
# Encontrar en: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service_role key (llave completa)

# --- JWT (generado por ESTA API, independiente del JWT de Supabase) ---
# Genera uno seguro con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- App ---
APP_ENV=development  # development | production
